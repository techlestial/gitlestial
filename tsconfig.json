{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["src/cli.ts", "src/commands/**/*", "src/lib/**/*"],
  "exclude": ["node_modules", "dist", "test", "src/services", "src/index.ts", "src/test.ts"]
}
